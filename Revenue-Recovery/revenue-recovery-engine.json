{
    "name": "[Client] - Butter Code Revenue Recovery™ — Collections Engine",
    "flow": [
        {
            "id": 1,
            "module": "google-sheets:searchRows",
            "version": 2,
            "parameters": {
                "__IMTCONN__": null
            },
            "mapper": {
                "mode": "select",
                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                "sheetId": "Invoices",
                "tableFirstRow": "A1:O1",
                "limit": 50,
                "filter": [
                    [
                        {
                            "a": "{{1.Status}}",
                            "b": "PAID",
                            "o": "text:notequal"
                        },
                        {
                            "a": "{{1.Status}}",
                            "b": "CANCELLED",
                            "o": "text:notequal"
                        },
                        {
                            "a": "{{1.`Due Date`}}",
                            "b": "{{formatDate(addDays(now; 4); \"YYYY-MM-DD\")}}",
                            "o": "date:less"
                        }
                    ]
                ]
            },
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {
                    "parameters": {
                        "__IMTCONN__": {
                            "label": "My Google connection"
                        },
                        "spreadsheetId": {
                            "label": "Invoices"
                        },
                        "sheetId": {
                            "label": "Invoices"
                        }
                    }
                }
            }
        },
        {
            "id": 2,
            "module": "builtin:BasicFeeder",
            "version": 1,
            "parameters": {},
            "mapper": {
                "array": "{{1.array}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                }
            }
        },
        {
            "id": 3,
            "module": "util:SetMultipleVariables2",
            "version": 1,
            "parameters": {},
            "mapper": {
                "scope": "roundtrip",
                "variables": [
                    {
                        "name": "days_overdue",
                        "value": "{{floor((toNumber(formatDate(now; \"X\")) - toNumber(formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"X\"))) / 86400)}}"
                    },
                    {
                        "name": "days_until_due",
                        "value": "{{floor((toNumber(formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"X\")) - toNumber(formatDate(now; \"X\"))) / 86400)}}"
                    },
                    {
                        "name": "reminder_count",
                        "value": "{{if(isEmpty(2.`Reminder Count`); 0; toNumber(2.`Reminder Count`))}}"
                    },
                    {
                        "name": "has_promised_date",
                        "value": "{{if(isEmpty(2.`Promised Pay Date`); \"NO\"; \"YES\")}}"
                    },
                    {
                        "name": "promise_missed",
                        "value": "{{if(isEmpty(2.`Promised Pay Date`); \"NO\"; if(toNumber(formatDate(parseDate(2.`Promised Pay Date`; \"YYYY-MM-DD\"); \"X\")) < toNumber(formatDate(now; \"X\")); \"YES\"; \"NO\"))}}"
                    },
                    {
                        "name": "first_name",
                        "value": "{{if(contains(2.`Client Name`; \" \"); trim(substring(2.`Client Name`; 0; indexOf(2.`Client Name`; \" \"))); trim(2.`Client Name`))}}"
                    }
                ]
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                }
            }
        },
        {
            "id": 4,
            "module": "builtin:BasicRouter",
            "version": 1,
            "mapper": null,
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 0
                }
            },
            "routes": [
                {
                    "name": "Pre-Due Reminder (3 days before)",
                    "flow": [
                        {
                            "id": 13,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "Due in 1-3 days, pre-due reminder not yet sent",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.days_until_due}}",
                                            "b": "1",
                                            "o": "number:greaterequal"
                                        },
                                        {
                                            "a": "{{3.days_until_due}}",
                                            "b": "3",
                                            "o": "number:lessequal"
                                        },
                                        {
                                            "a": "{{2.`Pre-Due Reminder Sent`}}",
                                            "b": "",
                                            "o": "text:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "{{2.`Client Email`}}"
                                ],
                                "subject": "Friendly reminder: Invoice {{2.`Invoice ID`}} due in {{3.days_until_due}} days",
                                "html": "<p>Hi {{3.first_name}},</p><p>Just a friendly heads-up — invoice <strong>{{2.`Invoice ID`}}</strong> for <strong>{{2.Description}}</strong> (R{{2.Amount}}) is due on <strong>{{formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}}</strong>.</p><p>Please arrange payment before or on that date. If you have any questions about the invoice, feel free to get in touch.</p><p>Payment can be made via:<br>EFT: [BANK NAME], Account: [ACCOUNT NUMBER], Ref: {{2.`Invoice ID`}}<br>[PAYMENT LINK — Ozow / PayFast — optional]</p><p>Thanks,<br>[OWNER NAME]<br>[BUSINESS NAME]</p>"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": -600
                                },
                                "restore": {
                                    "parameters": {
                                        "account": {
                                            "label": "My Gmail connection"
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "id": 14,
                            "module": "google-sheets:updateRow",
                            "version": 2,
                            "parameters": {
                                "__IMTCONN__": null
                            },
                            "mapper": {
                                "mode": "select",
                                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                                "sheetId": "Invoices",
                                "rowNumber": "{{2.__IMTROWNUM__}}",
                                "values": {
                                    "Pre-Due Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Last Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Notes": "{{2.Notes}} | Pre-due reminder sent {{formatDate(now; \"YYYY-MM-DD\")}} (due in {{3.days_until_due}} days)"
                                }
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1500,
                                    "y": -600
                                },
                                "restore": {
                                    "parameters": {
                                        "__IMTCONN__": {
                                            "label": "My Google connection"
                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Promise-to-Pay Missed",
                    "flow": [
                        {
                            "id": 15,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "Promised pay date has passed, not yet paid",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.has_promised_date}}",
                                            "b": "YES",
                                            "o": "text:equal"
                                        },
                                        {
                                            "a": "{{3.promise_missed}}",
                                            "b": "YES",
                                            "o": "text:equal"
                                        },
                                        {
                                            "a": "{{3.reminder_count}}",
                                            "b": "4",
                                            "o": "number:less"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "{{2.`Client Email`}}"
                                ],
                                "subject": "Payment not received — Invoice {{2.`Invoice ID`}} (promised {{2.`Promised Pay Date`}})",
                                "html": "<p>Hi {{3.first_name}},</p><p>We noted that you planned to settle invoice <strong>{{2.`Invoice ID`}}</strong> for <strong>{{2.Description}}</strong> (R{{2.Amount}}) by <strong>{{formatDate(parseDate(2.`Promised Pay Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}}</strong>, but we haven't received payment yet.</p><p>Could you let us know when we can expect this, or if anything has changed? We're happy to discuss a revised arrangement if needed.</p><p>Payment options:<br>EFT: [BANK NAME], Account: [ACCOUNT NUMBER], Ref: {{2.`Invoice ID`}}<br>[PAYMENT LINK — optional]</p><p>Thanks,<br>[OWNER NAME]<br>[BUSINESS NAME]</p>"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": -350
                                },
                                "restore": {
                                    "parameters": {
                                        "account": {
                                            "label": "My Gmail connection"
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "id": 16,
                            "module": "google-sheets:updateRow",
                            "version": 2,
                            "parameters": {
                                "__IMTCONN__": null
                            },
                            "mapper": {
                                "mode": "select",
                                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                                "sheetId": "Invoices",
                                "rowNumber": "{{2.__IMTROWNUM__}}",
                                "values": {
                                    "Status": "OVERDUE",
                                    "Last Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Reminder Count": "{{toNumber(2.`Reminder Count`) + 1}}",
                                    "Notes": "{{2.Notes}} | Promise-to-pay follow-up sent {{formatDate(now; \"YYYY-MM-DD\")}} (promised {{2.`Promised Pay Date`}}, still unpaid)"
                                }
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1500,
                                    "y": -350
                                },
                                "restore": {
                                    "parameters": {
                                        "__IMTCONN__": {
                                            "label": "My Google connection"
                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "First Reminder (3+ days overdue)",
                    "flow": [
                        {
                            "id": 5,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "3-6 days overdue, no reminder yet",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.days_overdue}}",
                                            "b": "3",
                                            "o": "number:greaterequal"
                                        },
                                        {
                                            "a": "{{3.reminder_count}}",
                                            "b": "0",
                                            "o": "number:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "{{2.`Client Email`}}"
                                ],
                                "subject": "Friendly reminder: Invoice {{2.`Invoice ID`}}",
                                "html": "<p>Hi {{3.first_name}},</p><p>Just a friendly reminder that invoice <strong>{{2.`Invoice ID`}}</strong> for <strong>{{2.Description}}</strong> (R{{2.Amount}}) was due on {{formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}}.</p><p>If you've already paid, please disregard this message — and thank you! If not, you can settle it whenever convenient. Let us know if you have any questions.</p><p>Payment options:<br>EFT: [BANK NAME], Account: [ACCOUNT NUMBER], Ref: {{2.`Invoice ID`}}<br>[PAYMENT LINK — optional]</p><p>Thanks,<br>[OWNER NAME]<br>[BUSINESS NAME]</p>"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": -100
                                },
                                "restore": {
                                    "parameters": {
                                        "account": {
                                            "label": "My Gmail connection"
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "id": 6,
                            "module": "google-sheets:updateRow",
                            "version": 2,
                            "parameters": {
                                "__IMTCONN__": null
                            },
                            "mapper": {
                                "mode": "select",
                                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                                "sheetId": "Invoices",
                                "rowNumber": "{{2.__IMTROWNUM__}}",
                                "values": {
                                    "Status": "OVERDUE",
                                    "Last Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Reminder Count": "1",
                                    "Notes": "{{2.Notes}} | 1st reminder sent {{formatDate(now; \"YYYY-MM-DD\")}} ({{3.days_overdue}} days overdue)"
                                }
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1500,
                                    "y": -100
                                },
                                "restore": {
                                    "parameters": {
                                        "__IMTCONN__": {
                                            "label": "My Google connection"
                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Second Reminder (7+ days overdue)",
                    "flow": [
                        {
                            "id": 7,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "7-13 days overdue, 1 reminder sent",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.days_overdue}}",
                                            "b": "7",
                                            "o": "number:greaterequal"
                                        },
                                        {
                                            "a": "{{3.reminder_count}}",
                                            "b": "1",
                                            "o": "number:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "{{2.`Client Email`}}"
                                ],
                                "subject": "Second reminder: Invoice {{2.`Invoice ID`}} now {{3.days_overdue}} days overdue",
                                "html": "<p>Hi {{3.first_name}},</p><p>This is a follow-up on invoice <strong>{{2.`Invoice ID`}}</strong> for <strong>{{2.Description}}</strong> (R{{2.Amount}}), which was due on {{formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}} and is now {{3.days_overdue}} days overdue.</p><p>Could you let us know when we can expect payment, or flag if there's an issue we can help resolve? We're happy to discuss a payment arrangement if needed.</p><p>Payment options:<br>EFT: [BANK NAME], Account: [ACCOUNT NUMBER], Ref: {{2.`Invoice ID`}}<br>[PAYMENT LINK — optional]</p><p>Thanks,<br>[OWNER NAME]<br>[BUSINESS NAME]</p>"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": 150
                                },
                                "restore": {
                                    "parameters": {
                                        "account": {
                                            "label": "My Gmail connection"
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "id": 8,
                            "module": "google-sheets:updateRow",
                            "version": 2,
                            "parameters": {
                                "__IMTCONN__": null
                            },
                            "mapper": {
                                "mode": "select",
                                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                                "sheetId": "Invoices",
                                "rowNumber": "{{2.__IMTROWNUM__}}",
                                "values": {
                                    "Status": "OVERDUE",
                                    "Last Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Reminder Count": "2",
                                    "Notes": "{{2.Notes}} | 2nd reminder sent {{formatDate(now; \"YYYY-MM-DD\")}} ({{3.days_overdue}} days overdue)"
                                }
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1500,
                                    "y": 150
                                },
                                "restore": {
                                    "parameters": {
                                        "__IMTCONN__": {
                                            "label": "My Google connection"
                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Final Reminder (14+ days overdue)",
                    "flow": [
                        {
                            "id": 9,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "14-29 days overdue, 2 reminders sent",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.days_overdue}}",
                                            "b": "14",
                                            "o": "number:greaterequal"
                                        },
                                        {
                                            "a": "{{3.reminder_count}}",
                                            "b": "2",
                                            "o": "number:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "{{2.`Client Email`}}"
                                ],
                                "subject": "Final reminder: Invoice {{2.`Invoice ID`}} — {{3.days_overdue}} days overdue",
                                "html": "<p>Hi {{3.first_name}},</p><p>We still haven't received payment for invoice <strong>{{2.`Invoice ID`}}</strong> for <strong>{{2.Description}}</strong> (R{{2.Amount}}), now {{3.days_overdue}} days overdue (originally due {{formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}}).</p><p>Please arrange payment as soon as possible, or get in touch so we can work out a plan together.</p><p>Payment options:<br>EFT: [BANK NAME], Account: [ACCOUNT NUMBER], Ref: {{2.`Invoice ID`}}<br>[PAYMENT LINK — optional]</p><p>Thanks,<br>[OWNER NAME]<br>[BUSINESS NAME]</p>"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": 400
                                },
                                "restore": {
                                    "parameters": {
                                        "account": {
                                            "label": "My Gmail connection"
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "id": 10,
                            "module": "google-sheets:updateRow",
                            "version": 2,
                            "parameters": {
                                "__IMTCONN__": null
                            },
                            "mapper": {
                                "mode": "select",
                                "spreadsheetId": "REPLACE_WITH_SPREADSHEET_ID",
                                "sheetId": "Invoices",
                                "rowNumber": "{{2.__IMTROWNUM__}}",
                                "values": {
                                    "Status": "OVERDUE",
                                    "Last Reminder Sent": "{{formatDate(now; \"YYYY-MM-DD\")}}",
                                    "Reminder Count": "3",
                                    "Notes": "{{2.Notes}} | Final reminder sent {{formatDate(now; \"YYYY-MM-DD\")}} ({{3.days_overdue}} days overdue)"
                                }
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1500,
                                    "y": 400
                                },
                                "restore": {
                                    "parameters": {
                                        "__IMTCONN__": {
                                            "label": "My Google connection"
                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Escalation Alert (30+ days overdue)",
                    "flow": [
                        {
                            "id": 11,
                            "module": "gmail:sendEmail",
                            "version": 3,
                            "parameters": {
                                "account": null
                            },
                            "filter": {
                                "name": "30+ days overdue, 3 reminders sent",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{3.days_overdue}}",
                                            "b": "30",
                                            "o": "number:greaterequal"
                                        },
                                        {
                                            "a": "{{3.reminder_count}}",
                                            "b": "3",
                                            "o": "number:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "to": [
                                    "[OWNER EMAIL ADDRESS]"
                                ],
                                "cc": "{{if(isEmpty(2.`Manager Email`); \"\"; 2.`Manager Email`)}}{{if(isEmpty(2.`Finance Email`); \"\"; if(isEmpty(2.`Manager Email`); 2.`Finance Email`; \", \" + 2.`Finance Email`))}}",
                                "subject": "⚠️ Invoice {{2.`Invoice ID`}} is {{3.days_overdue}} days overdue — needs immediate attention",
                                "html": "<p><strong>Invoice {{2.`Invoice ID`}} requires your immediate attention.</strong></p><ul><li><strong>Client:</strong> {{2.`Client Name`}} ({{2.`Client Email`}})</li><li><strong>Description:</strong> {{2.Description}}</li><li><strong>Amount:</strong> R{{2.Amount}}</li><li><strong>Due Date:</strong> {{formatDate(parseDate(2.`Due Date`; \"YYYY-MM-DD\"); \"DD MMM YYYY\")}}</li><li><strong>Days Overdue:</strong> {{3.days_overdue}}</li><li><strong>Automated Reminders Sent:</strong> 3</li></ul><p>This client has not responded to 3 automated reminders. Consider a personal phone call or formal escalation.</p><p>The automated reminder sequence has now stopped. Please follow up manually.</p>"
                            },
