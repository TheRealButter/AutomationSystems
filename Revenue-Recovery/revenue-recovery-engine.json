                                        },
                                        "spreadsheetId": {
                                            "label": "Invoices"
                                        },
                                        "sheetId": {
                                            "label": "Invoices"
                                        }
                                    }
                                }
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "scheduling": {
            "type": "indefinitely",
            "interval": 1440
        },
        "notes": [
            "Butter Code Revenue Recovery™ V2 — Collections Engine.",
            "FREE STACK: Google Sheets + Gmail. Set schedule to run once daily (e.g. 08:00) after import.",
            "6-STAGE LADDER: Pre-Due (1-3 days before) → 1st Overdue (Day 3) → 2nd Overdue (Day 7) → Final (Day 14) → Escalation (Day 30). Plus: Promise-to-Pay missed follow-up.",
            "PRE-DUE: Filter catches invoices due within the next 4 days. Pre-Due Reminder Sent is set to the date sent — empty string filter detects unsent. Only fires once per invoice.",
            "PROMISE-TO-PAY: Owner fills in 'Promised Pay Date' column when a client commits to a date. If that date passes without payment, an automated follow-up fires. Owner must update Status=PAID to stop reminders.",
            "ESCALATION: Owner + optional Manager Email + Finance Email are notified at Day 30 via CC. Leave Manager Email and Finance Email blank if not applicable.",
            "tableFirstRow is A1:O1 (15 columns matching V2 Invoices sheet). Replace REPLACE_WITH_SPREADSHEET_ID.",
            "Replace [OWNER NAME], [BUSINESS NAME], [OWNER EMAIL ADDRESS], [BANK NAME], [ACCOUNT NUMBER], and optionally [PAYMENT LINK] in each email template.",
            "When client pays: owner sets Status=PAID in the sheet — this stops all further reminders.",
            "2.__IMTROWNUM__ is Make.com's standard row reference. Re-map if needed from module 2's output."
        ]
    }
}
